/*
 * feature-pipeline.dot — Attractor showcase example
 *
 * Demonstrates every feature implemented in Epics 1–3:
 *
 *   Epic 1 — DOT parsing & graph model
 *     graph/node/edge attributes, value types (string/int/bool/duration),
 *     chained edges, subgraph scoped defaults, class derivation from
 *     subgraph labels, node/edge default blocks, $goal variable expansion,
 *     model_stylesheet with *, .class, and #id selectors, comments.
 *
 *   Epic 2 — execution engine & core handlers
 *     start (Mdiamond), exit (Msquare), codergen (box), conditional
 *     (diamond), tool (parallelogram); goal_gate + retry_target at both
 *     graph and node level; max_retries, allow_partial, auto_status;
 *     timeout, fidelity modes (full/compact/truncate/summary:*),
 *     fidelity override on edges (highest precedence); thread_id session
 *     reuse; edge conditions (outcome=, context.*=, weight tiebreak);
 *     typed events; ArtifactStore; CLI simulation mode.
 *
 *   Epic 3 — human-in-the-loop (Interviewer pattern)
 *     wait.human handler (hexagon); [K] accelerator-key syntax on edge
 *     labels; ConsoleInterviewer, AutoApproveInterviewer, CallbackInterviewer.
 *
 * NOT shown: parallel fan-out (component) and fan-in (tripleoctagon) —
 * those are Epic 4, which is in progress.
 */

digraph FeaturePipeline {

    // ── Graph-level attributes ─────────────────────────────────────────────

    graph [
        goal             = "Implement, review, and ship a new feature",
        label            = "Feature Pipeline",

        // default_max_retries applies to every node that omits max_retries
        default_max_retries = 1,

        // default_fidelity: compact = structured bullet-point context summary
        default_fidelity = "compact",

        // graph-level retry_target: jumped to if any goal_gate fails at exit
        retry_target     = "plan",

        // model_stylesheet: CSS-like rules for LLM model/provider/effort.
        //   *         → universal (lowest specificity)
        //   .class    → class-name match (medium)
        //   #node_id  → exact node ID (highest)
        model_stylesheet = "
            * { llm_model: claude-sonnet-4-6; llm_provider: anthropic; reasoning_effort: medium; }
            .careful { llm_model: claude-opus-4-8; reasoning_effort: high; }
            .fast    { llm_model: claude-haiku-4-5; reasoning_effort: low; }
            #plan    { reasoning_effort: low; }
        "
    ]

    // Node and edge default blocks — apply to all subsequent declarations
    // in this scope; individual nodes/edges may override.
    node [shape=box, timeout="900s"]
    edge [weight=0]


    // ── Entry and exit ─────────────────────────────────────────────────────

    start [shape=Mdiamond, label="Start"]
    done  [shape=Msquare,  label="Done"]


    // ── Planning subgraph ──────────────────────────────────────────────────
    //
    // Subgraphs scope node defaults: both nodes below inherit
    // thread_id="plan-thread" and fidelity="full", so they reuse the same
    // LLM session (full = conversation history preserved).
    //
    // Class derivation: label="Planning" → class "planning" for stylesheet.
    // (Not targeted in this stylesheet, but the mechanism is live.)

    subgraph cluster_planning {
        label = "Planning"
        node [thread_id="plan-thread", fidelity="full", timeout="600s"]

        // #plan rule from stylesheet lowers reasoning_effort to low.
        // $goal is expanded at parse time via VariableExpansionTransform.
        plan [
            label       = "Plan Feature",
            prompt      = "Create a detailed step-by-step plan for: $goal",
            max_retries = 0
        ]

        // .fast class → haiku model via stylesheet (explicit class overrides
        // the subgraph-derived "planning" class for stylesheet matching).
        scope [
            label  = "Define Scope",
            prompt = "Define acceptance criteria and out-of-scope boundaries for: $goal",
            class  = "fast"
        ]
    }


    // ── Implementation subgraph ────────────────────────────────────────────
    //
    // Separate thread for implementation; nodes share "impl-thread" so
    // the LLM sees full conversation context across implement and write_tests.

    subgraph cluster_impl {
        label = "Implementation"
        node [thread_id="impl-thread", fidelity="full", timeout="1800s"]

        implement [
            label         = "Implement Feature",
            prompt        = "Implement the plan step by step for: $goal",

            // goal_gate: pipeline cannot exit until this node reaches
            // SUCCESS or PARTIAL_SUCCESS.
            goal_gate     = true,

            // max_retries=2: up to 3 total executions (1 initial + 2 retries)
            max_retries   = 2,

            // allow_partial: accept PARTIAL_SUCCESS when retries are exhausted
            allow_partial = true,

            // node-level retry_target overrides the graph-level one
            retry_target  = "plan"
        ]

        write_tests [
            label     = "Write Unit Tests",
            prompt    = "Write comprehensive unit tests for the implementation of: $goal",
            class     = "careful",    // .careful → opus model from stylesheet
            goal_gate = true
        ]
    }


    // ── Quality checks ─────────────────────────────────────────────────────

    // Tool handler (parallelogram): runs a shell command; returns
    // outcome=success on exit code 0, outcome=fail on non-zero.
    run_tests [
        shape        = parallelogram,
        label        = "Run Test Suite",
        type         = "tool",
        tool_command = "make test",
        timeout      = "300s"
    ]

    // Codergen node interprets the test run output and writes a named
    // context key so the downstream diamond can route on a stable value
    // rather than on the transient "outcome" key (which the ConditionalHandler
    // overwrites with SUCCESS when it executes).
    evaluate_results [
        label    = "Evaluate Test Results",
        prompt   = "Summarise test output. Set context_update quality_verdict to 'pass' or 'fail'.",
        class    = "fast",
        fidelity = "summary:medium"
    ]

    // Conditional routing node (diamond): a pass-through whose outgoing edge
    // conditions check context values written by the preceding codergen node.
    quality_gate [shape=diamond, label="Quality gate?"]

    // Code review — .careful class → claude-opus via stylesheet;
    // fidelity="summary:high" gives the reviewer rich context (~3000 tokens).
    // retry_target overrides the graph-level setting for this node only.
    code_review [
        label        = "Code Review",
        class        = "careful",
        prompt       = "Review the implementation for correctness, security, and quality: $goal",
        goal_gate    = true,
        fidelity     = "summary:high",
        retry_target = "implement"
    ]


    // ── Human approval gate ────────────────────────────────────────────────
    //
    // WaitForHumanHandler blocks until an Interviewer (Console/Callback/Auto)
    // returns a selection.  Edge labels use [K] accelerator-key syntax;
    // ConsoleInterviewer presents the key in brackets for one-keystroke input.

    approval [
        shape = hexagon,
        label = "Approve pull request for merge?",
        type  = "wait.human"
    ]


    // ── Deployment and wrap-up ─────────────────────────────────────────────

    deploy [
        shape        = parallelogram,
        label        = "Deploy to Staging",
        type         = "tool",
        tool_command = "make deploy-staging",
        timeout      = "600s"
    ]

    // auto_status=true: if the handler writes no status.json the engine
    // synthesises {"outcome":"success"} automatically so the pipeline continues.
    announce [
        label       = "Draft Release Notes",
        class       = "fast",
        prompt      = "Write concise release notes for: $goal",
        auto_status = true
    ]


    // ── Edges ──────────────────────────────────────────────────────────────

    // Chained edge: A -> B -> C expands to A->B and B->C; attributes apply
    // to every hop.  Here both edges are unconditional (weight=0, no label).
    start -> plan -> scope

    // Edge-level fidelity override has the highest precedence in fidelity
    // resolution (beats node attribute, subgraph default, graph default).
    scope -> implement [condition="outcome=success", fidelity="compact"]
    scope -> plan      [condition="outcome=fail", label="Revise plan", weight=1]

    implement -> write_tests [condition="outcome=success"]
    implement -> plan        [condition="outcome=fail", label="[R] Rethink approach"]

    // Chained: write_tests -> run_tests -> evaluate_results
    write_tests -> run_tests -> evaluate_results [condition="outcome=success"]
    write_tests -> implement [condition="outcome=fail", label="Fix test compilation"]

    evaluate_results -> quality_gate

    // Diamond routing on context.quality_verdict written by evaluate_results.
    // weight= ensures a deterministic winner if the LLM returns an unexpected value.
    quality_gate -> code_review [label="Pass", condition="context.quality_verdict=pass", weight=2]
    quality_gate -> implement   [label="Fail", condition="context.quality_verdict=fail", weight=1]

    code_review -> approval  [condition="outcome=success"]
    code_review -> implement [condition="outcome=fail", label="Fix review comments"]

    // Human gate: three choices with [K] accelerator keys.
    // WaitForHumanHandler returns suggested_next_ids = [selected edge target].
    // Edge selection Step 3 (suggested_next_ids) then picks the right edge.
    approval -> deploy    [label="[A] Approve and deploy"]
    approval -> implement [label="[C] Request changes"]
    approval -> done      [label="[S] Skip — merge only"]

    deploy -> announce [condition="outcome=success", weight=2]
    deploy -> approval [condition="outcome=fail",    label="Deploy failed — retry"]

    announce -> done
}
