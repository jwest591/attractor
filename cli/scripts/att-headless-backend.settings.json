{
  "_comment": "Settings for ClaudeCodeHeadlessBackend. Do NOT add a $schema field (breaks hook registration on v2.1.114+).",
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '$CLAUDE_PROJECT_DIR/cli/scripts/ctx-usage.sh init'",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'CLAUDE_CONTEXT_CRITICAL=85 $CLAUDE_PROJECT_DIR/cli/scripts/context-ceiling.sh'",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
