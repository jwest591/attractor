{
  "_comment": "Settings for ClaudeCodeHeadlessBackend. Do NOT add a $schema field (breaks hook registration on v2.1.114+).",
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "statusLine": [
      {
        "type": "command",
        "command": "sh -c '$CLAUDE_PROJECT_DIR/cli/scripts/att-status-line.sh'",
        "timeout": 5000
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '$CLAUDE_PROJECT_DIR/cli/scripts/att-pretooluse.sh'",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
