{
  "_comment": "DEBUG settings for ClaudeCodeTmuxBackend — all 26 hook events logged via logger.sh to $ATTRACTOR_NODE_LOG_DIR. Switch between this and att-tmux-backend.settings.nolog.json by retargeting the att-tmux-backend.settings.json symlink. Do NOT add a $schema field (breaks hook registration on v2.1.114+).",
  "_comment_danger_prompt": "skipDangerousModePermissionPrompt suppresses the interactive confirmation prompt that Claude Code shows when running in --dangerously-skip-permissions mode. ClaudeCodeTmuxBackend drives an automated pipeline session and cannot respond to interactive prompts; without this flag the session stalls waiting for user input that never arrives.",
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "type": "command",
    "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/att-status-line.sh'",
    "padding": 0
  },
  "hooks": {
    "SessionStart": [
      { "matcher": "*",       "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh SessionStart star'" } ] },
      { "matcher": "startup", "hooks": [
        { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/att-session-start.sh'", "timeout": 5000 },
        { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh SessionStart startup'" }
      ]},
      { "matcher": "resume",  "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh SessionStart resume'" } ] },
      { "matcher": "clear",   "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh SessionStart clear'" } ] },
      { "matcher": "compact", "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh SessionStart compact'" } ] }
    ],

    "InstructionsLoaded": [
      { "matcher": "*",                "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh InstructionsLoaded star'" } ] },
      { "matcher": "session_start",    "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh InstructionsLoaded session_start'" } ] },
      { "matcher": "nested_traversal", "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh InstructionsLoaded nested_traversal'" } ] },
      { "matcher": "path_glob_match",  "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh InstructionsLoaded path_glob_match'" } ] },
      { "matcher": "include",          "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh InstructionsLoaded include'" } ] },
      { "matcher": "compact",          "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh InstructionsLoaded compact'" } ] }
    ],

    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh UserPromptSubmit'" } ] }
    ],

    "PreToolUse": [
      { "matcher": "*",         "hooks": [
        { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PreToolUse star'" },
        { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/att-pretooluse.sh'", "timeout": 5000 }
      ]},
      { "matcher": "TodoWrite", "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PreToolUse TodoWrite'" } ] },
      { "matcher": "Bash",      "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PreToolUse Bash'" } ] },
      { "matcher": "Task",      "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PreToolUse Task'" } ] }
    ],

    "PermissionRequest": [
      { "matcher": "*",     "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PermissionRequest star'" } ] },
      { "matcher": "Bash",  "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PermissionRequest Bash'" } ] },
      { "matcher": "Edit",  "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PermissionRequest Edit'" } ] },
      { "matcher": "Write", "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PermissionRequest Write'" } ] },
      { "matcher": "Task",  "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PermissionRequest Task'" } ] }
    ],

    "PermissionDenied": [
      { "matcher": "*",     "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PermissionDenied star'" } ] },
      { "matcher": "Bash",  "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PermissionDenied Bash'" } ] },
      { "matcher": "Edit",  "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PermissionDenied Edit'" } ] },
      { "matcher": "Write", "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PermissionDenied Write'" } ] },
      { "matcher": "Task",  "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PermissionDenied Task'" } ] }
    ],

    "PostToolUse": [
      { "matcher": "*",         "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PostToolUse star'" } ] },
      { "matcher": "TodoWrite", "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PostToolUse TodoWrite'" } ] },
      { "matcher": "Bash",      "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PostToolUse Bash'" } ] },
      { "matcher": "Task",      "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PostToolUse Task'" } ] }
    ],

    "PostToolUseFailure": [
      { "matcher": "*",     "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PostToolUseFailure star'" } ] },
      { "matcher": "Bash",  "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PostToolUseFailure Bash'" } ] },
      { "matcher": "Edit",  "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PostToolUseFailure Edit'" } ] },
      { "matcher": "Write", "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PostToolUseFailure Write'" } ] },
      { "matcher": "Task",  "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PostToolUseFailure Task'" } ] }
    ],

    "Notification": [
      { "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh Notification'" } ] }
    ],

    "SubagentStart": [
      { "matcher": "*",               "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh SubagentStart star'" } ] },
      { "matcher": "Explore",         "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh SubagentStart Explore'" } ] },
      { "matcher": "Plan",            "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh SubagentStart Plan'" } ] },
      { "matcher": "general-purpose", "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh SubagentStart general-purpose'" } ] }
    ],

    "SubagentStop": [
      { "matcher": "*",               "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh SubagentStop star'" } ] },
      { "matcher": "Explore",         "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh SubagentStop Explore'" } ] },
      { "matcher": "Plan",            "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh SubagentStop Plan'" } ] },
      { "matcher": "general-purpose", "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh SubagentStop general-purpose'" } ] }
    ],

    "TaskCreated": [
      { "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh TaskCreated'" } ] }
    ],

    "TaskCompleted": [
      { "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh TaskCompleted'" } ] }
    ],

    "Stop": [
      { "hooks": [
        { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh Stop'" },
        { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/att-stop.sh'", "timeout": 5000 }
      ]}
    ],

    "StopFailure": [
      { "matcher": "*",                     "hooks": [
        { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh StopFailure star'" },
        { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/att-stop.sh'", "timeout": 5000 }
      ]},
      { "matcher": "rate_limit",            "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh StopFailure rate_limit'" } ] },
      { "matcher": "overloaded",            "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh StopFailure overloaded'" } ] },
      { "matcher": "authentication_failed", "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh StopFailure authentication_failed'" } ] },
      { "matcher": "oauth_org_not_allowed", "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh StopFailure oauth_org_not_allowed'" } ] },
      { "matcher": "billing_error",         "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh StopFailure billing_error'" } ] },
      { "matcher": "invalid_request",       "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh StopFailure invalid_request'" } ] },
      { "matcher": "model_not_found",       "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh StopFailure model_not_found'" } ] },
      { "matcher": "server_error",          "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh StopFailure server_error'" } ] },
      { "matcher": "max_output_tokens",     "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh StopFailure max_output_tokens'" } ] },
      { "matcher": "unknown",               "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh StopFailure unknown'" } ] }
    ],

    "TeammateIdle": [
      { "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh TeammateIdle'" } ] }
    ],

    "ConfigChange": [
      { "matcher": "*",                "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh ConfigChange star'" } ] },
      { "matcher": "user_settings",    "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh ConfigChange user_settings'" } ] },
      { "matcher": "project_settings", "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh ConfigChange project_settings'" } ] },
      { "matcher": "local_settings",   "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh ConfigChange local_settings'" } ] },
      { "matcher": "policy_settings",  "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh ConfigChange policy_settings'" } ] },
      { "matcher": "skills",           "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh ConfigChange skills'" } ] }
    ],

    "CwdChanged": [
      { "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh CwdChanged'" } ] }
    ],

    "FileChanged": [
      { "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh FileChanged'" } ] }
    ],

    "PreCompact": [
      { "matcher": "manual", "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PreCompact manual'" } ] },
      { "matcher": "auto",   "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PreCompact auto'" } ] }
    ],

    "PostCompact": [
      { "matcher": "*",      "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PostCompact star'" } ] },
      { "matcher": "manual", "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PostCompact manual'" } ] },
      { "matcher": "auto",   "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh PostCompact auto'" } ] }
    ],

    "Elicitation": [
      { "matcher": "*", "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh Elicitation star'" } ] }
    ],

    "ElicitationResult": [
      { "matcher": "*", "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh ElicitationResult star'" } ] }
    ],

    "SessionEnd": [
      { "matcher": "*",                           "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh SessionEnd star'" } ] },
      { "matcher": "clear",                       "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh SessionEnd clear'" } ] },
      { "matcher": "resume",                      "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh SessionEnd resume'" } ] },
      { "matcher": "logout",                      "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh SessionEnd logout'" } ] },
      { "matcher": "prompt_input_exit",           "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh SessionEnd prompt_input_exit'" } ] },
      { "matcher": "bypass_permissions_disabled", "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh SessionEnd bypass_permissions_disabled'" } ] },
      { "matcher": "other",                       "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh SessionEnd other'" } ] }
    ],

    "WorktreeCreate": [
      { "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh WorktreeCreate'" } ] }
    ],

    "WorktreeRemove": [
      { "hooks": [ { "type": "command", "command": "sh -c '$ATTRACTOR_SCRIPTS_DIR/logger.sh WorktreeRemove'" } ] }
    ]
  }
}
